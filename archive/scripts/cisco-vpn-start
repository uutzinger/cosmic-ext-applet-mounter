#!/usr/bin/env bash
set -euo pipefail

SERVICE="vpnagentd.service"

open_cisco_vpn_client() {
    if [ -x /opt/cisco/secureclient/bin/vpnui ]; then
        echo "Opening Cisco Secure Client..."
        nohup /opt/cisco/secureclient/bin/vpnui >/dev/null 2>&1 &
    elif command -v gtk-launch >/dev/null 2>&1; then
        echo "Opening Cisco Secure Client..."
        gtk-launch com.cisco.secureclient.gui >/dev/null 2>&1 &
    else
        echo "Cisco Secure Client GUI command not found. Open it from the app launcher."
    fi
}

echo "Starting Cisco Secure Client VPN agent..."
sudo systemctl start "$SERVICE"

echo
echo "Status:"
systemctl is-active "$SERVICE"

echo
open_cisco_vpn_client
