{
  "app-id": "io.github.uutzinger.cosmic-ext-applet-mounter",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "cosmic-ext-applet-mounter",
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--share=ipc",
    "--device=dri",
    "--filesystem=xdg-config/cosmic/com.system76.CosmicTheme.Mode:ro",
    "--filesystem=xdg-config/cosmic/com.system76.CosmicTheme.Light:ro",
    "--filesystem=xdg-config/cosmic/com.system76.CosmicTheme.Dark:ro",
    "--filesystem=xdg-config/cosmic/io.github.uutzinger.cosmic-ext-applet-mounter:create",
    "--filesystem=xdg-config/cosmic-ext-applet-mounter:create",
    "--filesystem=xdg-config/systemd/user:create",
    "--filesystem=xdg-cache/cosmic-ext-applet-mounter:create",
    "--filesystem=~/.local/state/cosmic-ext-applet-mounter:create",
    "--talk-name=org.freedesktop.Flatpak"
  ],
  "modules": [
    {
      "name": "cosmic-ext-applet-mounter-gui-prototype",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm0755 cosmic-ext-applet-mounter /app/bin/cosmic-ext-applet-mounter",
        "install -Dm0755 cosmic-ext-applet-mounter-onedrive-auth-helper /app/bin/cosmic-ext-applet-mounter-onedrive-auth-helper",
        "install -Dm0644 app.desktop /app/share/applications/io.github.uutzinger.cosmic-ext-applet-mounter.desktop",
        "install -Dm0644 app.metainfo.xml /app/share/metainfo/io.github.uutzinger.cosmic-ext-applet-mounter.metainfo.xml",
        "install -Dm0644 icon.svg /app/share/icons/hicolor/scalable/apps/io.github.uutzinger.cosmic-ext-applet-mounter.svg"
      ],
      "sources": [
        {
          "type": "file",
          "path": "../../target/release/cosmic-ext-applet-mounter"
        },
        {
          "type": "file",
          "path": "../../scripts/cosmic-ext-applet-mounter-onedrive-auth-helper"
        },
        {
          "type": "file",
          "path": "../../resources/app.desktop"
        },
        {
          "type": "file",
          "path": "../../resources/app.metainfo.xml"
        },
        {
          "type": "file",
          "path": "../../resources/icon.svg"
        }
      ]
    }
  ]
}
