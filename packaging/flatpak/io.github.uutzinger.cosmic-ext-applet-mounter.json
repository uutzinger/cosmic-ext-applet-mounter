{
  "id": "io.github.uutzinger.cosmic-ext-applet-mounter",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "base": "com.system76.Cosmic.BaseApp",
  "base-version": "stable",
  "command": "cosmic-ext-applet-mounter",
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--share=ipc",
    "--device=dri",
    "--talk-name=com.system76.CosmicSettingsDaemon",
    "--talk-name=org.freedesktop.Flatpak",
    "--filesystem=xdg-config/cosmic/com.system76.CosmicTheme.Mode:ro",
    "--filesystem=xdg-config/cosmic/com.system76.CosmicTheme.Light:ro",
    "--filesystem=xdg-config/cosmic/com.system76.CosmicTheme.Dark:ro",
    "--filesystem=xdg-config/cosmic/io.github.uutzinger.cosmic-ext-applet-mounter:create",
    "--filesystem=xdg-config/cosmic-ext-applet-mounter:create",
    "--filesystem=xdg-config/systemd/user:create",
    "--filesystem=xdg-cache/cosmic-ext-applet-mounter:create",
    "--filesystem=~/.local/state/cosmic-ext-applet-mounter:create"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/cosmic-ext-applet-mounter/cargo",
      "RUST_BACKTRACE": "1"
    }
  },
  "modules": [
    {
      "name": "cosmic-ext-applet-mounter",
      "buildsystem": "simple",
      "build-commands": [
        "cargo --offline fetch --manifest-path Cargo.toml --verbose",
        "cargo --offline build --release --locked",
        "install -Dm0755 target/release/cosmic-ext-applet-mounter /app/bin/cosmic-ext-applet-mounter",
        "install -Dm0755 scripts/cosmic-ext-applet-mounter-onedrive-auth-helper /app/bin/cosmic-ext-applet-mounter-onedrive-auth-helper",
        "install -Dm0644 resources/app.desktop /app/share/applications/io.github.uutzinger.cosmic-ext-applet-mounter.desktop",
        "install -Dm0644 resources/app.metainfo.xml /app/share/metainfo/io.github.uutzinger.cosmic-ext-applet-mounter.metainfo.xml",
        "install -Dm0644 resources/icon.svg /app/share/icons/hicolor/scalable/apps/io.github.uutzinger.cosmic-ext-applet-mounter.svg"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/uutzinger/cosmic-ext-applet-mounter.git",
          "tag": "v0.4.1"
        },
        "./cargo-sources.json"
      ]
    }
  ]
}
