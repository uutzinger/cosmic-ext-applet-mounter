            remote_reference: "example-gdrive",
            remote_subpath: Some("Projects"),
            local_path: "/home/example/Cloud/Google",
            enabled: true,
            vpn_profile_id: None,
            disconnect_vpn_when_unused: false,
            tuning_profile: Balanced,
        ),
    ],
    vpn_profiles: [],
)
