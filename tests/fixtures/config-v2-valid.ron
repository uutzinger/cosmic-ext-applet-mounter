(
    schema_version: 2,
    notifications_enabled: true,
    connections: [
        (
            id: "2a3f5d45-e867-47e7-943f-66cf60e777ad",
            name: "Example Google Drive",
            provider: GoogleDrive,
            mode: OfflineMirror((
                recovery_directory: "/home/example/.local/share/cosmic-mounter/recovery/google",
                sync_interval_minutes: 15,
                sync_on_metered: false,
