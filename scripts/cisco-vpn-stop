#!/usr/bin/env bash
set -euo pipefail

SERVICE="vpnagentd.service"

echo "Closing Cisco Secure Client GUI if running..."
pkill -f '/opt/cisco/secureclient/bin/vpnui' 2>/dev/null || true
pkill -f 'vpnui' 2>/dev/null || true

echo "Stopping Cisco Secure Client VPN agent..."
sudo systemctl stop "$SERVICE"

echo
echo "Agent status:"
systemctl is-active "$SERVICE" || true

echo
echo "Remaining Cisco GUI processes:"
pgrep -a -f '/opt/cisco/secureclient/bin/vpnui|vpnui' || echo "  none"

echo
echo "Remaining VPN tunnel/interface check:"
if ip addr | grep -Eiq 'cscotun|vpn|tun|utun'; then
    ip addr | grep -Ei 'cscotun|vpn|tun|utun'
else
    echo "  no obvious Cisco tunnel interface found"
fi

echo
echo "Remaining VPN route check:"
if ip route | grep -Eiq 'cisco|tun|vpn|172\.|10\.|128\.196|150\.135'; then
    ip route | grep -Ei 'cisco|tun|vpn|172\.|10\.|128\.196|150\.135'
else
    echo "  no obvious VPN/private/UA routes found"
fi
